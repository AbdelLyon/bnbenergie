# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/bnbenergie"

# Payload CMS
# IMPORTANT: Utiliser un secret aléatoire de minimum 32 caractères
# Générer avec: openssl rand -base64 32
PAYLOAD_SECRET="votre-secret-32-caracteres-minimum-ici"

# Revalidation ISR
# Secret pour sécuriser l'endpoint de revalidation
# Générer avec: openssl rand -base64 24
REVALIDATION_SECRET="votre-secret-revalidation-ici"

# URLs du serveur
# En développement
SERVER_URL="http://localhost:3000"
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# En production
# SERVER_URL="https://bnbenergie.fr"
# NEXT_PUBLIC_SERVER_URL="https://bnbenergie.fr"

# Storage (Vercel Blob)
# Obtenir depuis: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN="votre-token-vercel-blob"

# Configuration Email (SMTP) - Optionnel
# Nécessaire pour le formulaire de contact
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="votre-mot-de-passe-smtp"
CONTACT_EMAIL="contact@bnbenergie.fr"

# SEO - Optionnel
NEXT_PUBLIC_GOOGLE_VERIFICATION="votre-code-verification-google"
NEXT_PUBLIC_SITE_URL="https://bnbenergie.fr"

# Environnement
NODE_ENV="development"

# Notes:
# - Ne jamais commiter le fichier .env.local
# - En production, définir ces variables dans le dashboard Vercel
# - Les variables NEXT_PUBLIC_* sont exposées au client
# - Toutes les autres variables sont privées (serveur uniquement)
